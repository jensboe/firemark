{
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "ng serve",
      "type": "firefox",
      "request": "launch",
      "url": "http://localhost:4200/",
      "tmpDir": "~/tmp",
      "preLaunchTask": "npm: start"
    },
    {
      "name": "ng test",
      "type": "firefox",
      "request": "launch",
      "preLaunchTask": "npm: test",
      "url": "http://localhost:9876/debug.html",
      "tmpDir": "~/tmp"
    },
    {
      "name": "Python: Django",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/backend/manage.py",
      "args": [
        "runserver",
        "--noreload"
      ],
      "django": true
    },
    {
      "name": "Python: Django(WITH reload)",
      "type": "python",
      "request": "launch",
      "cwd": "${workspaceFolder}/backend",
      "program": "manage.py",
      "args": [
        "runserver"
      ],
      "django": true
    },
    {
      "name": "Python: Aktuelle Datei",
      "type": "python",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal"
    }
  ]
}